# ============================================
# Competitive Intelligence Agent — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# === LLM (DeepSeek) ===
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MODEL=deepseek-reasoner  # 复杂推理用这个

# === Claude API (备用) ===
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# === Feishu (lark) ===
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx

# === Web Search (pick one) ===
# Option A: Tavily Search API (recommended — free 1000/month, AI-optimized)
TAVILY_API_KEY=tvly-xxx
# Option B: Bing Search API
BING_SEARCH_API_KEY=xxx
# Option C: SerpAPI
SERPAPI_KEY=xxx
# Option D: DuckDuckGo (free, no key needed, blocked in China)

# === Database ===
SQLITE_PATH=./data/intel.db
CHROMA_PATH=./data/chroma

# === Server ===
HOST=127.0.0.1
PORT=8000

# === Ngrok (optional, only needed for Feishu webhook mode) ===
NGROK_AUTH_TOKEN=xxx
