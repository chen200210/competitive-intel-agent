# ============================================
# Competitive Intelligence Agent - Environment
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# === Required: primary LLM ===
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# Optional heavier reasoning model:
# DEEPSEEK_MODEL=deepseek-reasoner

# === Optional: backup LLM (currently reserved) ===
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# === Required: Feishu bot and push ===
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx

# === Search ===
# Recommended and currently used by the code:
TAVILY_API_KEY=tvly-xxx
# Reserved placeholders, not part of the current main deployment path:
# BING_SEARCH_API_KEY=xxx
# SERPAPI_KEY=xxx

# === Database / local state ===
SQLITE_PATH=./data/intel.db
# Reserved path for optional vector/chroma usage:
CHROMA_PATH=./data/chroma

# === Optional: health API ===
HOST=127.0.0.1
PORT=8000

# === Optional: only for future webhook/ngrok mode ===
NGROK_AUTH_TOKEN=xxx
